# FlowClaw Configuration
# Copy this file to .env and fill in your values.

# NOTE: FlowClaw only reads credentials from environment variables and .env files
# by default. Set FLOWCLAW_LOAD_OPENCLAW_CONFIG=true to also load from
# ~/.openclaw/openclaw.json (see Credential Isolation section below).

# ── Core ─────────────────────────────────────────────
# Required: API key for authenticating requests to FlowClaw
WORKFLOW_EXECUTOR_API_KEY=your-secret-api-key-here

# Required: Notion integration token (starts with "secret_...")
NOTION_API_KEY=your-notion-api-key

# Server port (default: 8765)
PORT=8765

# Bind address (default: 127.0.0.1 for local only, 0.0.0.0 for all interfaces)
HOST=127.0.0.1

# ── Credential Isolation ─────────────────────────────────────────────────────
# By default, FlowClaw only reads credentials from environment variables
# and .env files. Set this to "true" to also load missing credentials
# from ~/.openclaw/openclaw.json. Only enable this if you understand
# that ALL credentials in your OpenClaw config become accessible to FlowClaw.
FLOWCLAW_LOAD_OPENCLAW_CONFIG=false

# ── Integrations (optional) ──────────────────────────
# Discord bot token for notifications (requires Send Messages permission)
DISCORD_BOT_TOKEN=your-discord-bot-token

# n8n API key — used if FlowClaw needs to call n8n webhooks
N8N_API_KEY=your-n8n-api-key

# OpenClaw gateway URL — for agent dispatch via sessions_spawn
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# ── Performance ──────────────────────────────────────
# Gunicorn worker count (recommended: 2× CPU cores)
MAX_WORKERS=4
